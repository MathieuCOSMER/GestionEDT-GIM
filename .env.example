# Copiez ce fichier en ".env" (jamais commité) et renseignez les valeurs.
# En production, définissez plutôt ces variables dans l'interface de l'hébergeur.

# Clé secrète des sessions (obligatoire). Générez-en une avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
EDT_SECRET_KEY=

# Mot de passe du compte Admin (recommandé pour ne pas l'avoir en clair dans le code)
EDT_ADMIN_PASSWORD=

# Mettre à 1 uniquement en développement local (jamais en production)
EDT_DEBUG=0
