{
  "name": "gestion-edt",
  "version": "1.0.0",
  "description": "Application de Gestion des Emplois Du Temps",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "cd frontend && npm run dev",
    "dev:backend": "node backend/server.js",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "init-db": "node scripts/init-db.js",
    "seed": "node scripts/seed-db.js",
    "setup": "npm install && cd frontend && npm install && cd .. && npm run init-db && npm run seed"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
